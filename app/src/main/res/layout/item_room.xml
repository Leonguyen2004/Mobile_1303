<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Thông tin phòng -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Tên phòng -->
            <TextView
                android:id="@+id/item_tv_room_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phòng 101"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#212121"
                android:layout_marginBottom="4dp" />

            <!-- Giá thuê -->
            <TextView
                android:id="@+id/item_tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2,500,000 VND"
                android:textSize="14sp"
                android:textColor="#1565C0"
                android:layout_marginBottom="4dp" />

            <!-- Tình trạng -->
            <TextView
                android:id="@+id/item_tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Còn trống"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- Thông tin người thuê -->
            <TextView
                android:id="@+id/item_tv_tenant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#757575"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Nút Xóa -->
        <Button
            android:id="@+id/item_btn_delete"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Xóa"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#F44336"
            android:minWidth="64dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="visible" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
