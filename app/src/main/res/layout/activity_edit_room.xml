<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1565C0"
            android:gravity="center"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️  Sửa thông tin phòng"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Form bên trong Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Mã phòng (không cho sửa) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mã phòng"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <EditText
                    android:id="@+id/edit_edt_room_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mã phòng"
                    android:focusable="false"
                    android:enabled="false"
                    android:inputType="text"
                    android:background="@android:drawable/edit_text"
                    android:padding="10dp"
                    android:layout_marginBottom="14dp" />

                <!-- Tên phòng -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên phòng *"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <EditText
                    android:id="@+id/edit_edt_room_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nhập tên phòng"
                    android:inputType="text"
                    android:background="@android:drawable/edit_text"
                    android:padding="10dp"
                    android:layout_marginBottom="14dp" />

                <!-- Giá thuê -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Giá thuê (VNĐ/tháng) *"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <EditText
                    android:id="@+id/edit_edt_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nhập giá thuê"
                    android:inputType="numberDecimal"
                    android:background="@android:drawable/edit_text"
                    android:padding="10dp"
                    android:layout_marginBottom="14dp" />

                <!-- Tình trạng phòng -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tình trạng phòng *"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <RadioGroup
                    android:id="@+id/edit_rg_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <RadioButton
                        android:id="@+id/edit_rb_empty"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Còn trống"
                        android:textColor="#2E7D32" />

                    <RadioButton
                        android:id="@+id/edit_rb_occupied"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Đã thuê"
                        android:textColor="#C62828" />
                </RadioGroup>

                <!-- Thông tin người thuê (ẩn/hiện theo tình trạng) -->
                <LinearLayout
                    android:id="@+id/edit_layout_tenant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Tên người thuê -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tên người thuê *"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:paddingBottom="4dp" />

                    <EditText
                        android:id="@+id/edit_edt_tenant_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nhập tên người thuê"
                        android:inputType="textPersonName"
                        android:background="@android:drawable/edit_text"
                        android:padding="10dp"
                        android:layout_marginBottom="14dp" />

                    <!-- SĐT người thuê -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Số điện thoại người thuê *"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:paddingBottom="4dp" />

                    <EditText
                        android:id="@+id/edit_edt_tenant_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nhập số điện thoại"
                        android:inputType="phone"
                        android:background="@android:drawable/edit_text"
                        android:padding="10dp"
                        android:layout_marginBottom="14dp" />
                </LinearLayout>

                <!-- Nút Cập nhật -->
                <Button
                    android:id="@+id/edit_btn_update"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CẬP NHẬT"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1565C0"
                    android:textColor="#FFFFFF"
                    android:padding="14dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
